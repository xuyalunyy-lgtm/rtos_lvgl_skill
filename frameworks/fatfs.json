{
  "framework_id": "fatfs",
  "name": "FatFS",
  "description": "FAT 文件系统",
  "category": "storage",
  "platforms": ["esp32", "stm32"],
  "constraints": [
    {"id": "FATFS-1", "name": "断电恢复", "severity": "P0", "detection": "manual",
     "description": "写入中断电可能导致文件系统损坏"},
    {"id": "FATFS-2", "name": "Flash 写入阻塞", "severity": "P1", "detection": "regex",
     "description": "Flash 写入可能阻塞实时任务", "related_core_constraint": "C35"},
    {"id": "FATFS-3", "name": "Mount/unmount 对称", "severity": "P1", "detection": "regex",
     "description": "f_mount 必须有对应的 f_unmount", "related_core_constraint": "C33"}
  ],
  "detect_patterns": {
    "includes": ["ff.h", "fatfs_vfs.h", "esp_vfs_fat.h"],
    "sdkconfig": ["CONFIG_FATFS", "CONFIG_ESP_VFS_FAT"]
  }
}
