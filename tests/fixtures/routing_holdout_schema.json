{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Routing Holdout Test Set",
  "description": "Schema for the blind holdout test set. Actual data is stored as encrypted GitHub secret ROUTING_HOLDOUT_JSON.",
  "type": "object",
  "required": ["meta", "samples"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["version", "total", "distribution", "pass_criteria"],
      "properties": {
        "version": {"type": "integer", "const": 1},
        "total": {"type": "integer", "const": 36},
        "distribution": {
          "type": "object",
          "description": "Number of samples per category",
          "properties": {
            "code_review": {"type": "integer", "const": 3},
            "memory_analysis": {"type": "integer", "const": 3},
            "project_review": {"type": "integer", "const": 3},
            "hw_sw_debug": {"type": "integer", "const": 3},
            "crash_debug": {"type": "integer", "const": 3},
            "lvgl_page": {"type": "integer", "const": 3},
            "app_manifest": {"type": "integer", "const": 3},
            "new_module": {"type": "integer", "const": 3},
            "bring_up": {"type": "integer", "const": 3},
            "sdk_trim": {"type": "integer", "const": 3},
            "clarification": {"type": "integer", "const": 6}
          }
        },
        "pass_criteria": {
          "type": "object",
          "properties": {
            "min_overall_conformance": {"type": "number", "const": 0.95},
            "max_false_auto_routes": {"type": "integer", "const": 0},
            "max_false_clarifications": {"type": "integer", "const": 2}
          }
        },
        "language_distribution": {
          "type": "object",
          "properties": {
            "zh": {"type": "integer", "minimum": 16},
            "en": {"type": "integer", "minimum": 16},
            "mixed_platform_terms": {"type": "integer", "minimum": 6}
          }
        }
      }
    },
    "samples": {
      "type": "array",
      "minItems": 36,
      "maxItems": 36,
      "items": {
        "type": "object",
        "required": ["id", "request"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z_]+[0-9]+$"},
          "request": {"type": "string", "minLength": 1},
          "expected_workflow": {
            "type": "string",
            "enum": ["code_review", "memory_analysis", "project_review", "hw_sw_debug",
                     "crash_debug", "lvgl_page", "app_manifest", "new_module",
                     "bring_up", "sdk_trim"]
          },
          "expected_clarification": {"type": "boolean"},
          "platform": {"type": "string"},
          "rtos": {"type": "string"},
          "tags": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Test tags: typo, colloquial, negation, long_desc, multi_goal, platform_mixed, hw_jargon"
          }
        },
        "oneOf": [
          {"required": ["expected_workflow"]},
          {"required": ["expected_clarification"]}
        ]
      }
    }
  }
}
