{
  "schema_version": "2.0",
  "app": {
    "id": "affirmation_app",
    "entry_page": "home",
    "navigation": { "mode": "stack", "max_depth": 8 }
  },
  "display": { "width": 480, "height": 800, "color_format": "RGB565" },
  "shared": {
    "assets": {
      "icon_back": "assets/icons/system/icon_back.png",
      "icon_battery": "assets/icons/system/icon_battery.png"
    },
    "fonts": {
      "title": "fonts/lvgl/40_bold.c",
      "body": "fonts/lvgl/20_bold.c",
      "caption": "fonts/lvgl/14_regular.c"
    }
  },
  "models": [
    {
      "name": "favorites",
      "fields": [
        { "name": "is_favorited", "type": "bool", "default": false }
      ]
    }
  ],
  "pages": [
    {
      "id": "home",
      "design": "designs/home_default.png",
      "template": "interactive_scene",
      "states": ["default", "favorited"],
      "state_designs": {
        "default": "designs/home_default.png",
        "favorited": "designs/home_favorited.png"
      },
      "events": [
        {
          "node_id": "favorite_button",
          "trigger": "clicked",
          "actions": [
            { "type": "model_toggle", "target": "favorites.is_favorited" },
            { "type": "set_state", "state": "favorited" }
          ]
        },
        {
          "node_id": "detail_button",
          "trigger": "clicked",
          "actions": [
            { "type": "route", "route_id": "home_to_detail" }
          ]
        }
      ]
    },
    {
      "id": "detail",
      "design": "designs/detail_default.png",
      "template": "generic",
      "states": ["default", "loading", "error"],
      "state_designs": {
        "default": "designs/detail_default.png",
        "loading": "designs/detail_loading.png",
        "error": "designs/detail_error.png"
      },
      "events": [
        {
          "node_id": "settings_button",
          "trigger": "clicked",
          "actions": [
            { "type": "route", "route_id": "detail_to_settings" }
          ]
        }
      ]
    },
    {
      "id": "settings",
      "design": "designs/settings_default.png",
      "template": "generic",
      "states": ["default"],
      "state_designs": {
        "default": "designs/settings_default.png"
      },
      "events": [
        {
          "node_id": "back_button",
          "trigger": "clicked",
          "actions": [
            { "type": "route", "route_id": "settings_back" }
          ]
        }
      ]
    }
  ],
  "routes": [
    {
      "id": "home_to_detail",
      "from": "home",
      "event": "detail_button.clicked",
      "to": "detail",
      "mode": "push"
    },
    {
      "id": "detail_to_settings",
      "from": "detail",
      "event": "settings_button.clicked",
      "to": "settings",
      "mode": "replace"
    },
    {
      "id": "settings_back",
      "from": "settings",
      "event": "back_button.clicked",
      "mode": "back"
    }
  ]
}
