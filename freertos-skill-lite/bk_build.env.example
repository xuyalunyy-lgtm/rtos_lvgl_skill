# BK 编译脚本配置示例（复制为 bk_build.env 或 bk_build.env.ps1 后修改）
#
# Linux / WSL / Git Bash:
#   cp bk_build.env.example bk_build.env
#
# Windows PowerShell:
#   复制内容为 bk_build.env.ps1

# ── SDK 路径（与 bk_build 脚本同级） ─────────────────────
# BK_SDK_DIR=bk_avdk_smp

# ── 工程（二选一） ───────────────────────────────────────
# 方案 A：SDK 内 Demo（相对 SDK 的 projects/ 路径）
# BK_PROJECT=lvgl/widgets

# 方案 B：外部方案仓工程目录
# BK_PROJECT_DIR=bk_solution_ai/projects/beken_genie

# ── 芯片目标 ─────────────────────────────────────────────
# BK_SOC=bk7258
