{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lvgl-ui-spec-v2",
  "title": "LVGL UI Spec v2",
  "description": "Structured UI specification for LVGL page generation. This is the central IR between visual analysis and code generation.",
  "type": "object",
  "required": ["schema_version", "page_name", "display", "lvgl_version", "nodes"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "page_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "maxLength": 64,
      "description": "Snake_case page identifier, used for function/file naming"
    },
    "display": {
      "$ref": "#/$defs/display_config"
    },
    "lvgl_version": {
      "type": "string",
      "enum": ["v8", "v9"],
      "description": "Target LVGL version — determines codegen backend"
    },
    "theme": {
      "$ref": "#/$defs/theme"
    },
    "fonts": {
      "type": "array",
      "items": { "$ref": "#/$defs/font_spec" },
      "maxItems": 16,
      "description": "Font resources required by this page"
    },
    "assets": {
      "type": "array",
      "items": { "$ref": "#/$defs/asset_spec" },
      "maxItems": 64,
      "description": "Image assets required by this page"
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/ui_node" },
      "minItems": 1,
      "maxItems": 256,
      "description": "Flat list of UI nodes (parent references form the tree)"
    },
    "events": {
      "type": "array",
      "items": { "$ref": "#/$defs/event_spec" },
      "maxItems": 32,
      "description": "Event handler declarations"
    },
    "data_bindings": {
      "type": "array",
      "items": { "$ref": "#/$defs/data_binding" },
      "maxItems": 32,
      "description": "Runtime data binding declarations"
    },
    "lifecycle": {
      "$ref": "#/$defs/lifecycle"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_design": { "type": "string", "description": "Path to source design image" },
        "generated_at": { "type": "string", "format": "date-time" },
        "generator_version": { "type": "string" },
        "total_nodes": { "type": "integer", "minimum": 0 },
        "total_assets_bytes": { "type": "integer", "minimum": 0 },
        "total_font_bytes": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "display_config": {
      "type": "object",
      "required": ["width", "height"],
      "additionalProperties": false,
      "properties": {
        "width": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "height": { "type": "integer", "minimum": 1, "maximum": 4096 },
        "rotation": { "type": "integer", "enum": [0, 90, 180, 270], "default": 0 },
        "color_format": { "type": "string", "enum": ["RGB565", "RGB565A8", "RGB888", "ARGB8888", "A8"], "default": "RGB565" }
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary_color": { "$ref": "#/$defs/hex_color" },
        "secondary_color": { "$ref": "#/$defs/hex_color" },
        "background_color": { "$ref": "#/$defs/hex_color" },
        "text_color": { "$ref": "#/$defs/hex_color" },
        "text_secondary_color": { "$ref": "#/$defs/hex_color" },
        "accent_color": { "$ref": "#/$defs/hex_color" },
        "error_color": { "$ref": "#/$defs/hex_color" },
        "success_color": { "$ref": "#/$defs/hex_color" }
      }
    },
    "hex_color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "description": "6-digit hex color, e.g. #2196F3"
    },
    "font_spec": {
      "type": "object",
      "required": ["name", "size"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$", "maxLength": 32 },
        "size": { "type": "integer", "minimum": 8, "maximum": 128 },
        "bpp": { "type": "integer", "enum": [1, 2, 4, 8], "default": 4 },
        "source_path": { "type": "string", "description": "Path to .ttf/.otf source" },
        "glyphs": { "type": "string", "description": "Explicit glyph set (auto-detected from nodes if omitted)" },
        "fallback": { "type": "string", "description": "Fallback font name" }
      }
    },
    "asset_spec": {
      "type": "object",
      "required": ["symbol", "source_path"],
      "additionalProperties": false,
      "properties": {
        "symbol": { "type": "string", "pattern": "^UI_IMG_[A-Z][A-Z0-9_]*$", "maxLength": 64 },
        "source_path": { "type": "string" },
        "color_format": { "type": "string", "enum": ["RGB565", "RGB565A8", "RGB888", "ARGB8888", "A8"], "default": "RGB565" },
        "compress": { "type": "string", "enum": ["none", "rle", "lz4"], "default": "none" },
        "auto_crop": { "type": "boolean", "default": true },
        "flash_bytes": { "type": "integer", "minimum": 0 },
        "sha256": { "type": "string" }
      }
    },
    "ui_node": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "maxLength": 48,
          "description": "Unique node identifier, used for variable naming"
        },
        "type": {
          "type": "string",
          "enum": ["screen", "container", "label", "button", "image", "bar", "slider", "switch", "checkbox", "dropdown", "roller", "spinner", "arc", "calendar", "chart", "keyboard", "list", "msgbox", "tabview", "tileview", "window"],
          "description": "LVGL widget type"
        },
        "parent_id": {
          "type": "string",
          "description": "Parent node ID (null/absent for screen root)"
        },
        "source_bbox": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 4,
          "maxItems": 4,
          "description": "[x, y, w, h] in design image pixels"
        },
        "layout": { "$ref": "#/$defs/layout_constraint" },
        "styles": { "$ref": "#/$defs/node_styles" },
        "text": {
          "type": "string",
          "maxLength": 512,
          "description": "Static text content (for label/button)"
        },
        "text_macro": {
          "type": "string",
          "pattern": "^UI_TEXT_[A-Z][A-Z0-9_]*$",
          "description": "Macro name for text (enables runtime updates)"
        },
        "src": {
          "type": "string",
          "description": "Image source (asset symbol or path)"
        },
        "src_macro": {
          "type": "string",
          "pattern": "^UI_IMG_SRC_[A-Z][A-Z0-9_]*$",
          "description": "Macro name for image source"
        },
        "value": {
          "type": "integer",
          "description": "Initial value (for bar/slider/switch)"
        },
        "range_min": { "type": "integer" },
        "range_max": { "type": "integer" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Detection confidence (0=guess, 1=certain)"
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 8,
          "description": "Detection evidence sources"
        },
        "absolute_layout_exception": {
          "type": "string",
          "description": "Required if using absolute positioning instead of Flex/Grid"
        }
      }
    },
    "layout_constraint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["flex-row", "flex-column", "grid", "absolute"],
          "default": "flex-column"
        },
        "flex_wrap": { "type": "string", "enum": ["nowrap", "wrap"], "default": "nowrap" },
        "flex_justify": { "type": "string", "enum": ["start", "center", "end", "space-between", "space-around", "space-evenly"], "default": "start" },
        "flex_align": { "type": "string", "enum": ["start", "center", "end", "stretch"], "default": "start" },
        "gap": { "type": "integer", "minimum": 0, "maximum": 256 },
        "padding": { "type": "integer", "minimum": 0, "maximum": 256 },
        "grid_columns": { "type": "array", "items": { "type": "integer" }, "maxItems": 16 },
        "grid_rows": { "type": "array", "items": { "type": "integer" }, "maxItems": 16 }
      }
    },
    "node_styles": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 },
        "bg_color": { "$ref": "#/$defs/hex_color" },
        "bg_opa": { "type": "integer", "minimum": 0, "maximum": 255 },
        "radius": { "type": "integer", "minimum": 0 },
        "border_width": { "type": "integer", "minimum": 0 },
        "border_color": { "$ref": "#/$defs/hex_color" },
        "shadow_width": { "type": "integer", "minimum": 0 },
        "text_color": { "$ref": "#/$defs/hex_color" },
        "text_font_size": { "type": "integer", "minimum": 8, "maximum": 128 },
        "text_align": { "type": "string", "enum": ["left", "center", "right"] },
        "pad_top": { "type": "integer", "minimum": 0 },
        "pad_bottom": { "type": "integer", "minimum": 0 },
        "pad_left": { "type": "integer", "minimum": 0 },
        "pad_right": { "type": "integer", "minimum": 0 }
      }
    },
    "event_spec": {
      "type": "object",
      "required": ["node_id", "event_type", "handler_name"],
      "additionalProperties": false,
      "properties": {
        "node_id": { "type": "string" },
        "event_type": { "type": "string", "enum": ["clicked", "pressed", "released", "value_changed", "focused", "defocused", "scroll", "gesture"] },
        "handler_name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
      }
    },
    "data_binding": {
      "type": "object",
      "required": ["node_id", "field", "source"],
      "additionalProperties": false,
      "properties": {
        "node_id": { "type": "string" },
        "field": { "type": "string", "enum": ["text", "value", "src", "hidden"] },
        "source": { "type": "string", "description": "Data source identifier" },
        "update_method": { "type": "string", "enum": ["async_call", "queue", "direct"], "default": "async_call" }
      }
    },
    "lifecycle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create_function": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "destroy_function": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "update_functions": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
          "maxItems": 16
        }
      }
    }
  }
}
