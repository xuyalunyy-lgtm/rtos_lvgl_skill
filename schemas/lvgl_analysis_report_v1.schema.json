{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lvgl-analysis-report-v1",
  "title": "LVGL Analysis Report v1",
  "description": "Output of visual analysis stage. Contains detected regions, text, colors, layout candidates, and confidence scores.",
  "type": "object",
  "required": ["schema_version", "page_name", "screen", "detected_regions", "confidence"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "page_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "screen": {
      "$ref": "lvgl_ui_spec_v2.schema.json#/$defs/display_config"
    },
    "detected_regions": {
      "type": "array",
      "items": { "$ref": "#/$defs/detected_region" },
      "maxItems": 512
    },
    "detected_text": {
      "type": "array",
      "items": { "$ref": "#/$defs/detected_text" },
      "maxItems": 256
    },
    "color_palette": {
      "type": "array",
      "items": { "$ref": "#/$defs/color_entry" },
      "maxItems": 32
    },
    "layout_candidates": {
      "type": "array",
      "items": { "$ref": "#/$defs/layout_candidate" },
      "maxItems": 64
    },
    "cutout_matches": {
      "type": "array",
      "items": { "$ref": "#/$defs/cutout_match" },
      "maxItems": 128
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Overall analysis confidence"
    },
    "uncertain_regions": {
      "type": "array",
      "items": { "$ref": "#/$defs/uncertain_region" },
      "maxItems": 32,
      "description": "Regions requiring human confirmation"
    },
    "questions": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 16,
      "description": "Questions for the user to resolve ambiguities"
    },
    "overlay_path": {
      "type": "string",
      "description": "Path to debug_overlay.png"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "analysis_duration_ms": { "type": "integer", "minimum": 0 },
        "image_width": { "type": "integer" },
        "image_height": { "type": "integer" },
        "algorithm_version": { "type": "string" }
      }
    }
  },
  "$defs": {
    "detected_region": {
      "type": "object",
      "required": ["id", "type", "bbox", "confidence"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "type": {
          "type": "string",
          "enum": ["container", "label", "button", "image", "bar", "slider", "switch", "card", "list_item", "header", "footer", "icon", "background", "unknown"]
        },
        "bbox": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 4,
          "maxItems": 4,
          "description": "[x, y, w, h] in design image pixels"
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 8
        },
        "children_ids": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs of child regions (for containers)"
        },
        "text_content": { "type": "string" },
        "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "layout_hint": { "type": "string", "enum": ["flex-row", "flex-column", "grid", "absolute"] }
      }
    },
    "detected_text": {
      "type": "object",
      "required": ["text", "bbox", "confidence"],
      "additionalProperties": false,
      "properties": {
        "text": { "type": "string" },
        "bbox": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 4,
          "maxItems": 4
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "font_size_estimate": { "type": "integer", "minimum": 1 },
        "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "region_id": { "type": "string" }
      }
    },
    "color_entry": {
      "type": "object",
      "required": ["hex", "ratio"],
      "additionalProperties": false,
      "properties": {
        "hex": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
        "ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "role": { "type": "string", "enum": ["background", "primary", "secondary", "text", "accent", "border", "shadow"] }
      }
    },
    "layout_candidate": {
      "type": "object",
      "required": ["region_ids", "mode", "confidence"],
      "additionalProperties": false,
      "properties": {
        "region_ids": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "mode": { "type": "string", "enum": ["flex-row", "flex-column", "grid"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "gap_estimate": { "type": "integer", "minimum": 0 },
        "alignment": { "type": "string" }
      }
    },
    "cutout_match": {
      "type": "object",
      "required": ["cutout_path", "bbox", "confidence", "status"],
      "additionalProperties": false,
      "properties": {
        "cutout_path": { "type": "string" },
        "bbox": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 4,
          "maxItems": 4
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "status": { "type": "string", "enum": ["used_cutout", "used_component_calibration", "duplicate_or_low_confidence", "unmatched_or_state_variant"] },
        "improvement_score": { "type": "number" },
        "region_id": { "type": "string" }
      }
    },
    "uncertain_region": {
      "type": "object",
      "required": ["bbox", "reason"],
      "additionalProperties": false,
      "properties": {
        "bbox": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 },
          "minItems": 4,
          "maxItems": 4
        },
        "reason": { "type": "string" },
        "candidates": {
          "type": "array",
          "items": { "type": "string" },
          "maxItems": 4
        }
      }
    }
  }
}
