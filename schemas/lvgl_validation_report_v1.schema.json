{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lvgl-validation-report-v1",
  "title": "LVGL Validation Report v1",
  "description": "Validation results for generated LVGL code — includes schema validation, compile status, render results, and visual comparison.",
  "type": "object",
  "required": ["schema_version", "page_name", "status", "stages"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "page_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["passed", "passed_with_warnings", "failed", "incomplete", "render_only"],
      "description": "Overall validation status. render_only = no baseline to compare against."
    },
    "stages": {
      "type": "object",
      "required": ["schema", "compile", "render"],
      "additionalProperties": false,
      "properties": {
        "schema": { "$ref": "#/$defs/stage_result" },
        "compile": { "$ref": "#/$defs/stage_result" },
        "render": { "$ref": "#/$defs/stage_result" },
        "visual_diff": { "$ref": "#/$defs/stage_result" }
      }
    },
    "schema_validation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "spec_valid": { "type": "boolean" },
        "errors": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "compile_result": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exit_code": { "type": "integer" },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "errors": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "render_result": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "render_path": { "type": "string", "description": "Path to rendered PNG" },
        "object_tree_path": { "type": "string", "description": "Path to object tree JSON" },
        "exit_code": { "type": "integer" },
        "errors": { "type": "array", "items": { "type": "string" } }
      }
    },
    "visual_diff": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "global_ssim": { "type": "number", "minimum": 0, "maximum": 1 },
        "changed_pixel_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "region_diffs": {
          "type": "array",
          "items": { "$ref": "#/$defs/region_diff" },
          "maxItems": 64
        },
        "text_diffs": {
          "type": "array",
          "items": { "$ref": "#/$defs/text_diff" },
          "maxItems": 64
        },
        "control_tree_diffs": {
          "type": "array",
          "items": { "$ref": "#/$defs/control_diff" },
          "maxItems": 64
        },
        "baseline_path": { "type": "string" },
        "actual_path": { "type": "string" },
        "diff_overlay_path": { "type": "string" }
      }
    },
    "resource_budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total_flash_bytes": { "type": "integer", "minimum": 0 },
        "total_ram_bytes": { "type": "integer", "minimum": 0 },
        "within_budget": { "type": "boolean" }
      }
    },
    "errors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Top-level error messages"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Top-level warning messages"
    }
  },
  "$defs": {
    "stage_result": {
      "type": "object",
      "required": ["status"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["passed", "passed_with_warnings", "failed", "skipped", "error"] },
        "duration_ms": { "type": "integer", "minimum": 0 },
        "message": { "type": "string" }
      }
    },
    "region_diff": {
      "type": "object",
      "required": ["region_id", "ssim"],
      "additionalProperties": false,
      "properties": {
        "region_id": { "type": "string" },
        "ssim": { "type": "number", "minimum": 0, "maximum": 1 },
        "bbox_iou": { "type": "number", "minimum": 0, "maximum": 1 },
        "status": { "type": "string", "enum": ["match", "mismatch", "missing", "extra"] }
      }
    },
    "text_diff": {
      "type": "object",
      "required": ["node_id", "expected", "actual"],
      "additionalProperties": false,
      "properties": {
        "node_id": { "type": "string" },
        "expected": { "type": "string" },
        "actual": { "type": "string" },
        "match": { "type": "boolean" }
      }
    },
    "control_diff": {
      "type": "object",
      "required": ["node_id", "diff_type"],
      "additionalProperties": false,
      "properties": {
        "node_id": { "type": "string" },
        "diff_type": { "type": "string", "enum": ["missing", "extra", "type_mismatch", "position_mismatch", "size_mismatch", "style_mismatch"] },
        "expected": { "type": "object" },
        "actual": { "type": "object" }
      }
    }
  }
}
