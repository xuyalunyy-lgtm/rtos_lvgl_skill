{
  "kind": "lvgl_page_plan",
  "schema_version": "1.2",
  "display": {
    "lvgl_version": "v8",
    "width": 240,
    "height": 320,
    "frame_budget_ms": 16,
    "max_flush_ms": 8
  },
  "ui_owner": {
    "task": "lvgl_task",
    "update_boundary": "queue"
  },
  "layout": {
    "mode": "responsive",
    "reference_width": 240,
    "reference_height": 320,
    "scale_policy": "native",
    "fixed_coordinate_rationale": ""
  },
  "transition_budget": {
    "max_create_ms": 8,
    "max_decode_ms": 0,
    "max_heap_alloc_bytes": 0
  },
  "initial_page": "home",
  "navigation": {
    "router_owner": "lvgl_task",
    "root_page": "home",
    "back_stack": "explicit",
    "interrupt_resume": "previous_or_fallback",
    "production_router_enabled": true,
    "reset_policy": "root_or_recovery"
  },
  "pages": [
    {
      "id": "home",
      "parent": null,
      "states": ["idle", "loading", "error"],
      "lifecycle": {
        "create_policy": "resident",
        "exit_policy": "hide",
        "fallback_target": "home"
      },
      "resources": {
        "cache_policy": "resident",
        "decode_policy": "predecoded",
        "decoded_cache_budget_bytes": 262144,
        "images": ["home_background"],
        "fonts": ["ui_regular"]
      },
      "refresh": {
        "dynamic_regions": ["status_row"],
        "full_screen_invalidate": false
      },
      "transitions": [
        {
          "event": "tap_settings",
          "to": "settings",
          "guard": "page_state == PAGE_IDLE",
          "kind": "forward",
          "stack_action": "push",
          "direction": "left"
        },
        {
          "event": "alarm_triggered",
          "to": "alarm",
          "guard": "alarm_pending",
          "kind": "interrupt",
          "stack_action": "push",
          "direction": "up",
          "priority": 100,
          "resume": "previous",
          "fallback_target": "home"
        }
      ]
    },
    {
      "id": "settings",
      "parent": "home",
      "states": ["idle", "saving", "error"],
      "lifecycle": {
        "create_policy": "lazy",
        "exit_policy": "destroy",
        "fallback_target": "home"
      },
      "resources": {
        "cache_policy": "lazy",
        "decode_policy": "filesystem",
        "decoded_cache_budget_bytes": 0,
        "images": [],
        "fonts": ["ui_regular"]
      },
      "refresh": {
        "dynamic_regions": ["settings_list"],
        "full_screen_invalidate": false
      },
      "transitions": [
        {
          "event": "tap_back",
          "to": "home",
          "guard": "page_state == PAGE_IDLE",
          "kind": "back",
          "stack_action": "pop",
          "direction": "right"
        }
      ]
    },
    {
      "id": "alarm",
      "parent": "home",
      "states": ["ringing", "acknowledged"],
      "lifecycle": {
        "create_policy": "lazy",
        "exit_policy": "destroy",
        "fallback_target": "home"
      },
      "resources": {
        "cache_policy": "lazy",
        "decode_policy": "filesystem",
        "decoded_cache_budget_bytes": 0,
        "images": [],
        "fonts": ["ui_regular"]
      },
      "refresh": {
        "dynamic_regions": ["alarm_state"],
        "full_screen_invalidate": false
      },
      "transitions": [
        {
          "event": "acknowledge_alarm",
          "to": "home",
          "guard": "page_state == ALARM_ACKNOWLEDGED",
          "kind": "return",
          "stack_action": "pop",
          "direction": "down",
          "resume": "previous",
          "fallback_target": "home"
        }
      ]
    }
  ]
}
