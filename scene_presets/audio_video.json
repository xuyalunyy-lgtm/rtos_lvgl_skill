{
  "name": "音视频设备",
  "id": "audio-video",
  "description": "音视频采集/播放设备，如摄像头、可视门铃、AV 会议终端",
  "platforms": ["esp32", "jl", "bk"],
  "required_constraints": [
    "C2", "C3", "C4", "C8", "C9", "C12", "C14",
    "C25", "C26", "C27", "C28", "C29", "C30", "C33",
    "C35", "C36", "C37", "C42", "C43", "C44"
  ],
  "recommended_prompts": [
    "prompts/av_pipeline_review.txt",
    "prompts/media_format_review.txt"
  ],
  "checker_suite": "media",
  "generator_params": {
    "display": true,
    "audio": true,
    "camera": true,
    "video_preview": true,
    "av_sync": true,
    "tasks": ["video_task", "audio_task", "av_sync_task", "ui_task"],
    "queues": ["video_frame_q", "audio_frame_q", "av_sync_q"]
  },
  "acceptance_checklist": [
    "音视频管道无阻塞（C25）",
    "编码格式与容器格式匹配（C26）",
    "时钟抖动 < 阈值（C27）",
    "DMA buffer 生命周期对称（C28）",
    "音视频同步误差 < 80ms（lip-sync）",
    "关键路径 copy budget 达标（C35/C36）",
    "背压策略正确：drop-oldest 或 block（C37）"
  ]
}
