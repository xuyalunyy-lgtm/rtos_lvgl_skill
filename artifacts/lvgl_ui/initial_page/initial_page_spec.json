{
  "schema": "freertos-embedded-architect.lvgl.initial-page.v1",
  "page_name": "initial_page",
  "mode": "two_cutout_layered_no_text",
  "display": {
    "width": 480,
    "height": 800,
    "lvgl_version": "v9"
  },
  "visible_layers": [
    {
      "id": "background",
      "type": "image",
