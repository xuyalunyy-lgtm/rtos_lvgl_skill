      "alias": "assets/initial_page_bg.jpg",
      "runtime_macro": "UI_IMG_SRC_INITIAL_PAGE_BG",
      "bbox": [0, 0, 480, 800]
    },
    {
      "id": "pet",
      "type": "image",
      "source": "ui/VidaWheel 硬件UI/宠物.png",
      "alias": "assets/initial_page_pet.png",
      "runtime_macro": "UI_IMG_SRC_INITIAL_PAGE_PET",
      "bbox": [95, 123, 305, 428]
    }
  ],
  "reference": {
    "source": "ui/初始页面.png",
    "alias": "assets/initial_page_reference.png",
    "bbox": [0, 0, 480, 800]
  }
}
