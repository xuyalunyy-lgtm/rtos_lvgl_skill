{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://freertos-skill.dev/schemas/board.json",
  "title": "Board Definition",
  "description": "硬件板卡注册定义。记录串口、烧录、监控、复位、电源控制等信息。",
  "type": "object",
  "required": ["board_id", "platform", "serial_port", "flash_cmd"],
  "properties": {
    "board_id": {"type": "string", "pattern": "^[a-z0-9-]{2,64}$"},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "platform": {"type": "string", "enum": ["esp32", "stm32", "zephyr", "jl", "bk"]},
    "serial_port": {"type": "string", "description": "串口设备路径，如 COM3, /dev/ttyUSB0"},
    "baudrate": {"type": "integer", "default": 115200},
    "flash_cmd": {"type": "string", "description": "烧录命令模板，{firmware} 为固件路径占位符"},
    "build_cmd": {"type": "string", "description": "构建命令"},
    "monitor_cmd": {"type": "string", "description": "串口监控命令"},
    "reset_cmd": {"type": "string", "description": "复位命令"},
    "power_cmd": {"type": "string", "description": "电源控制命令（开/关）"},
    "probe_cmd": {"type": "string", "description": "板卡探测命令"},
    "capabilities": {
      "type": "array",
      "description": "板卡支持的操作能力",
      "items": {
        "type": "string",
        "enum": ["flash", "monitor", "reset", "power", "jtag", "serial_cmd", "network_fault", "sensor_fault"]
      }
    },
    "safety_flags": {
      "type": "object",
      "properties": {
        "allow_flash": {"type": "boolean", "default": false},
        "allow_reset": {"type": "boolean", "default": false},
        "allow_power": {"type": "boolean", "default": false},
        "require_confirmation": {"type": "boolean", "default": true},
        "max_flash_per_hour": {"type": "integer", "default": 10}
      }
    },
    "tags": {"type": "array", "items": {"type": "string"}},
    "notes": {"type": "string"}
  }
}
