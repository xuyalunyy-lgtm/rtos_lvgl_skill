{
  "mcpServers": {
    "lvgl-ui-mcp": {
      "command": "python",
      "args": ["lvgl-ui-mcp/server.py"],
      "env": {
        "PYTHONUTF8": "1",
        "PYTHONIOENCODING": "utf-8",
        "LVGL_MCP_SERVER_NAME": "lvgl-ui-mcp",
        "LVGL_MCP_SERVER_VERSION": "0.1.0"
      }
    },
    "mqtt-mcp": {
      "command": "python",
      "args": ["mcp/mqtt_server.py"],
      "env": {
        "PYTHONUTF8": "1",
        "PYTHONIOENCODING": "utf-8",
        "MQTT_ALLOWED_HOSTS": "localhost,127.0.0.1"
      }
    },
    "ota-mcp": {
      "command": "python",
      "args": ["mcp/ota_server.py"],
      "env": {
        "PYTHONUTF8": "1",
        "PYTHONIOENCODING": "utf-8",
        "OTA_ALLOWED_HOSTS": "localhost,127.0.0.1"
      }
    },
    "serial-mcp": {
      "command": "python",
      "args": ["mcp/serial_server.py"],
      "env": {
        "PYTHONUTF8": "1",
        "PYTHONIOENCODING": "utf-8",
        "SERIAL_ALLOWED_PORTS": "*"
      }
    }
  }
}
