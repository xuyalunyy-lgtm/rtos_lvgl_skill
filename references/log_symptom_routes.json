{
  "symptoms": [
    {
      "id": "WDT_RESET",
      "name": "Task WDT 复位",
      "patterns": ["task_wdt", "WDT", "TIMERG", "watchdog", "wdt_reset", "TWDT"],
      "category": "software",
      "severity": "P0",
      "constraints": ["C31", "C15", "C35"],
      "root_cause_hints": ["长阻塞调用", "优先级反转", "队列满无限等待", "Flash/NVS 写入阻塞"],
      "recommended_commands": ["python tools/scheduler_analyzer.py --model rtos_model.json"],
      "architecture_flags": ["检查任务优先级是否合理", "检查是否有全局锁阻塞实时路径"]
    },
    {
      "id": "HARDFAULT",
      "name": "HardFault",
      "patterns": ["HardFault", "hardfault", "Guru Meditation", "abort\\(\\)", "panic"],
      "category": "software",
      "severity": "P0",
      "constraints": ["C4", "C2", "C12", "C44"],
      "root_cause_hints": ["空指针解引用", "栈溢出", "非法内存访问", "中断优先级错误"],
      "recommended_commands": ["addr2line -e firmware.elf 0xADDR"],
      "architecture_flags": ["检查是否有裸指针跨任务传递"]
    },
    {
      "id": "STACK_OVERFLOW",
      "name": "栈溢出",
      "patterns": ["stack overflow", "StackOverflow", "stack_overflow", "pxStack", "stack smashing"],
      "category": "software",
      "severity": "P0",
      "constraints": ["C7", "C30", "C35"],
      "root_cause_hints": ["任务栈太小", "局部变量过大", "递归过深", "TLS/加密栈需求高"],
      "recommended_commands": ["python tools/memory_lifetime_analyzer.py --model rtos_model.json"],
      "architecture_flags": ["检查任务拓扑是否合理分配栈"]
    },
    {
      "id": "HEAP_EXHAUSTION",
      "name": "堆耗尽",
      "patterns": ["malloc fail", "out of memory", "heap_caps_malloc.*NULL", "pvPortMalloc.*NULL"],
      "category": "software",
      "severity": "P0",
      "constraints": ["C3", "C7", "C36"],
      "root_cause_hints": ["内存泄漏", "cJSON 未释放", "大 buffer 未回收"],
      "recommended_commands": ["python tools/memory_lifetime_analyzer.py --model rtos_model.json"],
      "architecture_flags": ["检查是否有全局堆分配热路径", "检查是否有跨任务所有权不清的 buffer"]
    },
    {
      "id": "QUEUE_FULL",
      "name": "队列满",
      "patterns": ["queue full", "xQueueSend.*fail", "QUEUE_FULL", "drop"],
      "category": "software",
      "severity": "P1",
      "constraints": ["C37", "C2", "C30"],
      "root_cause_hints": ["消费者太慢", "队列深度不足", "缺少背压策略"],
